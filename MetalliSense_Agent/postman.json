  "item": [
    {
      "name": "🆕 Explainable AI Copilot",
      "item": [
        {
          "name": "1. Get Explanation for Analysis",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"composition\": {\n    \"Fe\": 94.5,\n    \"C\": 3.2,\n    \"Si\": 2.0,\n    \"Mn\": 0.4,\n    \"P\": 0.05,\n    \"S\": 0.10\n  },\n  \"grade\": \"GREY-IRON\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/copilot/explain",
              "host": ["{{base_url}}"],
              "path": ["copilot", "explain"]
            },
            "description": "Get human-readable explanation for ML predictions. Runs full agent analysis and generates natural language explanation using Groq LLM."
          },
          "response": []
        },
        {
          "name": "2. Interactive Chat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Why do we need to add Manganese?\",\n  \"include_context\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/copilot/chat",
              "host": ["{{base_url}}"],
              "path": ["copilot", "chat"]
            },
            "description": "Ask follow-up questions about the latest analysis. The copilot maintains conversation history for context-aware responses."
          },
          "response": []
        },
        {
          "name": "3. Chat - Alternative Questions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What happens if we don't correct this deviation?\",\n  \"include_context\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/copilot/chat",
              "host": ["{{base_url}}"],
              "path": ["copilot", "chat"]
            },
            "description": "Example of another question you can ask"
          },
          "response": []
        },
        {
          "name": "4. Clear Chat History",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/copilot/chat/history",
              "host": ["{{base_url}}"],
              "path": ["copilot", "chat", "history"]
            },
            "description": "Clear conversation history for a fresh start"
          },
          "response": []
        }
      ],
      "description": "Explainable AI endpoints using Groq LLM for natural language explanations"
    },
    {
      "name": "🎤 Voice Services",
      "item": [
        {
          "name": "1. Speech-to-Text (Transcribe)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "audio",
                  "type": "file",
                  "src": "/path/to/audio/file.wav",
                  "description": "Select an audio file (WAV, MP3, M4A, OGG, FLAC)"
                },
                {
                  "key": "language",
                  "value": "en",
                  "type": "text",
                  "description": "Optional: Language code (en, es, fr, etc.)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/copilot/voice/transcribe",
              "host": ["{{base_url}}"],
              "path": ["copilot", "voice", "transcribe"]
            },
            "description": "Convert voice input to text using Groq Whisper large-v3. Upload an audio file and get transcribed text."
          },
          "response": []
        },
        {
          "name": "2. Text-to-Speech (Synthesize)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Silicon addition of 0.22 percent is recommended to reach the target range for GREY-IRON.\",\n  \"language\": \"en\",\n  \"slow\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/copilot/voice/synthesize",
              "host": ["{{base_url}}"],
              "path": ["copilot", "voice", "synthesize"]
            },
            "description": "Convert text to speech (MP3 format). Returns audio file that can be played."
          },
          "response": []
        },
        {
          "name": "3. Get Supported Languages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/copilot/voice/languages",
              "host": ["{{base_url}}"],
              "path": ["copilot", "voice", "languages"]
            },
            "description": "Get list of supported languages for voice services (12 languages: en, es, fr, de, it, pt, ru, ja, ko, zh, hi, ar)"
          },
          "response": []
        }
      ],
      "description": "Voice interaction endpoints: Speech-to-Text and Text-to-Speech"
    },
