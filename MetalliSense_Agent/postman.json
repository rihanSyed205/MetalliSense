  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8001",
      "type": "string"
    },
    {
      "key": "test_composition",
      "value": "{\"Fe\":94.5,\"C\":3.2,\"Si\":2.0,\"Mn\":0.4,\"P\":0.05,\"S\":0.10}",
